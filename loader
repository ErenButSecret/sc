-- PARTİKÜL SİSTEMİ
-- ═══════════════════════════════════════════
local particleConnections = {}

local function spawnParticles(parent)
    -- Partikülleri tutar
    local particleContainer = Instance.new("Frame")
    particleContainer.Name = "Particles"
    particleContainer.Size = UDim2.new(1, 0, 1, 0)
    particleContainer.BackgroundTransparency = 1
    particleContainer.ZIndex = 0
    particleContainer.Parent = parent

    local function createParticle()
        if not particleContainer or not particleContainer.Parent then return end

        local p = Instance.new("Frame")
        p.Size = UDim2.new(0, math.random(4, 10), 0, math.random(4, 10))
        p.Position = UDim2.new(math.random() , 0, 1.05, 0)  -- ekranın altından başla
        p.BackgroundColor3 = Color3.fromRGB(
            math.random(80, 160),
            math.random(160, 220),
            math.random(40, 100)
        )
        p.BackgroundTransparency = math.random(20, 50) / 100
        p.BorderSizePixel = 0
        p.ZIndex = 1
        p.Parent = particleContainer

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = p

        -- Yukarı doğru uç
        local duration = math.random(30, 70) / 10  -- 3.0 - 7.0 saniye
        local targetX  = p.Position.X.Scale + (math.random(-15, 15) / 100)

        TweenService:Create(p, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            Position = UDim2.new(targetX, 0, -0.1, 0),
            BackgroundTransparency = 1,
            Size = UDim2.new(0, math.random(2, 6), 0, math.random(2, 6))
        }):Play()

        -- Süre sonunda temizle
        task.delay(duration, function()
            if p and p.Parent then p:Destroy() end
        end)
    end

    -- Düzenli aralıklarla parçacık oluştur
    local conn = RunService.Heartbeat:Connect(function()
        if math.random(1, 8) == 1 then  -- her frame ~1/8 ihtimalle
            pcall(createParticle)
        end
    end)
    table.insert(particleConnections, conn)

    return particleContainer
end

local function stopParticles()
    for _, conn in ipairs(particleConnections) do
        conn:Disconnect()
    end
    particleConnections = {}
end

