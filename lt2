local function UpdateESP()
    for _,v in pairs(espBBs) do pcall(function() v:Destroy() end) end espBBs={}
    if not _G.ESPToggled then return end
    for _,plr in pairs(Players:GetPlayers()) do
        if plr~=LP and plr.Character then
            local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
            local hum=plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum then
                local bb=Instance.new("BillboardGui",hrp) bb.Size=UDim2.new(0,150,0,50)
                bb.StudsOffset=Vector3.new(0,3,0) bb.AlwaysOnTop=true
                local n=Instance.new("TextLabel",bb) n.Size=UDim2.new(1,0,0,18) n.BackgroundTransparency=1
                n.Text=plr.Name n.TextColor3=C.Accent n.Font=Enum.Font.GothamBold n.TextSize=14
                n.TextStrokeTransparency=0.3 n.TextStrokeColor3=Color3.new(0,0,0)
                local info=Instance.new("TextLabel",bb) info.Size=UDim2.new(1,0,0,14) info.Position=UDim2.new(0,0,0,18)
                info.BackgroundTransparency=1 info.Font=Enum.Font.GothamMedium info.TextSize=12
                info.TextColor3=C.Text info.TextStrokeTransparency=0.3 info.TextStrokeColor3=Color3.new(0,0,0)
                local myR=getRoot()
                local dist=myR and math.floor((myR.Position-hrp.Position).Magnitude) or 0
                info.Text=string.format("HP: %d/%d | %dm",math.floor(hum.Health),math.floor(hum.MaxHealth),dist)
                local hl=Instance.new("Highlight",plr.Character) hl.Name="KiwiESP"
                hl.FillColor=C.Accent hl.FillTransparency=0.7 hl.OutlineColor=C.Accent
                hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
                table.insert(espBBs,bb) table.insert(espBBs,hl)
            end
        end
    end
end

task.spawn(function() while _G.MasterActive do
    if _G.ESPToggled then UpdateESP() else
        for _,v in pairs(espBBs) do pcall(function() v:Destroy() end) end espBBs={} end
