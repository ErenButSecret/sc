local function getAxStats(axName, treClass)
    -- 1. Önce modülden yüklemeyi dene
    local axeClasses = RepStorage:FindFirstChild("AxeClasses")
    if axeClasses then
        -- Doğrudan isimle dene
        local mod = axeClasses:FindFirstChild("AxeClass_"..axName)
        -- Bulamazsa tüm modülleri tara
        if not mod then
            for _, child in pairs(axeClasses:GetChildren()) do
                if child.Name:lower():find(axName:lower()) then
                    mod = child; break
                end
            end
        end
        if mod then
            -- Birden fazla require yöntemi dene
            local ok, s = pcall(function() return require(mod).new() end)
            if not ok then ok, s = pcall(function() return require(mod)() end) end
            if not ok then ok, s = pcall(function() local r = require(mod); return type(r) == "table" and r or nil end) end
            if ok and s then
                print("[Kiwi Hub] ✅ Balta modülü yüklendi: " .. axName)
                if s.SpecialTrees and s.SpecialTrees[treClass] then
                    for k,v in next, s.SpecialTrees[treClass] do s[k]=v end
                end
                return s
            else
                print("[Kiwi Hub] ⚠️ Modül bulundu ama yüklenemedi: " .. (mod.Name or "?"))
            end
        else
            print("[Kiwi Hub] ⚠️ AxeClasses'ta modül bulunamadı: AxeClass_" .. axName)
            print("[Kiwi Hub] 📂 Mevcut modüller:")
            for _, child in pairs(axeClasses:GetChildren()) do
                print("    → " .. child.Name)
            end
        end
    else
        print("[Kiwi Hub] ⚠️ ReplicatedStorage > AxeClasses klasörü bulunamadı!")
    end

    -- 2. Fallback: yedek istatistik tablosundan al
    local fb = FallbackAxeStats[axName]
    if fb then
        print("[Kiwi Hub] 🔄 Yedek istatistikler kullanılıyor: " .. axName .. " (Damage=" .. fb.Damage .. ", Cooldown=" .. fb.SwingCooldown .. ")")
        return {Damage = fb.Damage, SwingCooldown = fb.SwingCooldown}
    end

    -- 3. Hiçbiri bulunamazsa genel varsayılan
    print("[Kiwi Hub] 🔄 Bilinmeyen balta, varsayılan istatistikler: " .. axName)
    return {Damage = DefaultStats.Damage, SwingCooldown = DefaultStats.SwingCooldown}
end

local function getTreeOfClass(cls)
    local best = {}
    for _, r in next, Workspace:GetChildren() do
        if r.Name == "TreeRegion" then
            for _, t in next, r:GetChildren() do
                if t:IsA("Model") and t:FindFirstChild("TreeClass") and t.TreeClass.Value == cls then
                    if t:FindFirstChild("CutEvent") and (not t:FindFirstChild("Owner") or t.Owner.Value == nil) then
                        local m=0
                        for _, p in next, t:GetDescendants() do if p:IsA("BasePart") then m=m+p.Mass end end
                        table.insert(best, {tre=t, mass=m})
                    end
                end
            end
        end
    end
    table.sort(best, function(a,b) return a.mass > b.mass end)
    return best[1] and best[1].tre or nil
end

local function getAxe()
    for _, v in next, LP.Backpack:GetChildren() do if v:FindFirstChild("ToolName") then return v end end
    local ch = getChar()
    if ch then for _, v in next, ch:GetChildren() do if v:IsA("Tool") and v:FindFirstChild("ToolName") then return v end end end
    return nil
end

-- ═══ BRING WOOD FONKSİYONU (GREEN HUB TARZI) ═══
local function bringWoodType(woodType, color)
    local hrp = getRoot()
    if not hrp then notify("🥝 Kiwi Hub","Karakter bulunamadı!",2) return end
    local curpos = hrp.CFrame
    local target = getTreeOfClass(woodType)
    local ax = getAxe()
    if not target then notify("🥝 Kiwi Hub","❌ "..woodType.." ağacı bulunamadı!",2) return end
    if not ax then notify("🥝 Kiwi Hub","❌ Balta bulunamadı!",2) return end

    notify("🥝 Kiwi Hub","⏳ "..woodType.." getiriliyor...",3)
    local stats = getAxStats(ax.ToolName.Value, woodType)
    if not stats then notify("🥝 Kiwi Hub","❌ Balta istatistikleri alınamadı!",2) return end

    local newLog = nil
    local logModels = Workspace:FindFirstChild("LogModels")
    if not logModels then notify("🥝 Kiwi Hub","❌ LogModels bulunamadı!",2) return end

    local con = logModels.ChildAdded:Connect(function(l)
        task.wait()
        if l:FindFirstChild("Owner") and l.Owner.Value == LP then newLog = l end
    end)

    local lp = RS.Heartbeat:Connect(function()
        pcall(function() LP.Character.HumanoidRootPart.CFrame = target.WoodSection.CFrame + Vector3.new(5,3,0) end)
    end)

    local attempts = 0
    repeat
        pcall(function()
            RemoteProxy:FireServer(target.CutEvent, {
                tool = ax, height = 0.3, faceVector = Vector3.new(1,0,0),
                sectionId = 1, hitPoints = stats.Damage,
                cooldown = stats.SwingCooldown, cuttingClass = "Axe"
            })
        end)
        task.wait(stats.SwingCooldown or 0.3)
        attempts = attempts + 1
    until newLog ~= nil or attempts > 100

    lp:Disconnect()
    con:Disconnect()

    if newLog then
        task.wait(0.2)
        for i=1,60 do
            pcall(function()
                ClientDrag:FireServer(newLog)
                newLog:PivotTo(curpos)
            end)
            task.wait()
        end
        pcall(function() LP.Character.HumanoidRootPart.CFrame = curpos end)
        notify("🥝 Kiwi Hub","✅ "..woodType.." getirildi!",2)
    else
        pcall(function() LP.Character.HumanoidRootPart.CFrame = curpos end)
        notify("🥝 Kiwi Hub","❌ Ağaç kesilemedi!",2)
    end
end

