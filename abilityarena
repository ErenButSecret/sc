local function createPage(name)
    local page = Instance.new("ScrollingFrame")
    page.Name = name
    page.Size = UDim2.new(1, -20, 1, -20)
    page.Position = UDim2.new(0, 10, 0, 10)
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = C.Accent
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    page.Visible = false
    page.Parent = contentArea
    local lay = Instance.new("UIListLayout", page)
    lay.Padding = UDim.new(0, 8)
    lay.SortOrder = Enum.SortOrder.LayoutOrder
    Instance.new("UIPadding", page).PaddingBottom = UDim.new(0, 10)
    return page
end

local function createHeader(parent, text, ord)
    local h = Instance.new("TextLabel")
    h.Size = UDim2.new(1, 0, 0, 24)
    h.BackgroundTransparency = 1
    h.Text = "  " .. text
    h.TextSize = 11
    h.Font = Enum.Font.GothamBold
    h.TextColor3 = C.Accent
    h.TextXAlignment = Enum.TextXAlignment.Left
    h.LayoutOrder = ord
    h.Parent = parent
end

local function createToggle(parent, label, desc, ord, cb)
    local ctr = Instance.new("Frame")
    ctr.Size = UDim2.new(1, 0, 0, 52)
    ctr.BackgroundColor3 = C.Card
    ctr.BorderSizePixel = 0
    ctr.LayoutOrder = ord
    ctr.Parent = parent
    Instance.new("UICorner", ctr).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -80, 0, 20)
    lbl.Position = UDim2.new(0, 14, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextSize = 14
    lbl.Font = Enum.Font.GothamBold
    lbl.TextColor3 = C.Text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = ctr

    local dl = Instance.new("TextLabel")
    dl.Size = UDim2.new(1, -80, 0, 14)
    dl.Position = UDim2.new(0, 14, 0, 30)
    dl.BackgroundTransparency = 1
    dl.Text = desc
    dl.TextSize = 11
    dl.Font = Enum.Font.Gotham
    dl.TextColor3 = C.TextDim
    dl.TextXAlignment = Enum.TextXAlignment.Left
    dl.Parent = ctr

    local tbg = Instance.new("Frame")
    tbg.Size = UDim2.new(0, 44, 0, 24)
    tbg.Position = UDim2.new(1, -58, 0.5, -12)
    tbg.BackgroundColor3 = C.ToggleOff
    tbg.BorderSizePixel = 0
    tbg.Parent = ctr
    Instance.new("UICorner", tbg).CornerRadius = UDim.new(1, 0)

    local tc = Instance.new("Frame")
    tc.Size = UDim2.new(0, 18, 0, 18)
    tc.Position = UDim2.new(0, 3, 0, 3)
    tc.BackgroundColor3 = C.TextDim
    tc.BorderSizePixel = 0
    tc.Parent = tbg
    Instance.new("UICorner", tc).CornerRadius = UDim.new(1, 0)

    local isOn = false
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = ctr

    btn.MouseEnter:Connect(function() tw(ctr, 0.2, {BackgroundColor3 = C.CardHover}) end)
    btn.MouseLeave:Connect(function() tw(ctr, 0.2, {BackgroundColor3 = C.Card}) end)

    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        if isOn then
            tw(tbg, 0.25, {BackgroundColor3 = C.Accent})
            tw(tc, 0.25, {Position = UDim2.new(0, 23, 0, 3), BackgroundColor3 = Color3.new(1, 1, 1)})
        else
            tw(tbg, 0.25, {BackgroundColor3 = C.ToggleOff})
            tw(tc, 0.25, {Position = UDim2.new(0, 3, 0, 3), BackgroundColor3 = C.TextDim})
        end
        pcall(cb, isOn)
    end)
end

local function createSlider(parent, label, min, max, default, ord, cb)
    local ctr = Instance.new("Frame")
    ctr.Size = UDim2.new(1, 0, 0, 58)
    ctr.BackgroundColor3 = C.Card
    ctr.BorderSizePixel = 0
    ctr.LayoutOrder = ord
    ctr.Parent = parent
    Instance.new("UICorner", ctr).CornerRadius = UDim.new(0, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.6, 0, 0, 20)
    lbl.Position = UDim2.new(0, 14, 0, 6)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextSize = 13
    lbl.Font = Enum.Font.GothamBold
    lbl.TextColor3 = C.Text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = ctr

    local vl = Instance.new("TextLabel")
    vl.Size = UDim2.new(0.35, 0, 0, 20)
    vl.Position = UDim2.new(0.65, -14, 0, 6)
    vl.BackgroundTransparency = 1
    vl.Text = tostring(math.floor(default))
    vl.TextSize = 13
    vl.Font = Enum.Font.GothamBold
    vl.TextColor3 = C.Accent
    vl.TextXAlignment = Enum.TextXAlignment.Right
    vl.Parent = ctr

    local sbg = Instance.new("Frame")
    sbg.Size = UDim2.new(1, -28, 0, 6)
    sbg.Position = UDim2.new(0, 14, 0, 36)
    sbg.BackgroundColor3 = C.SliderBg
    sbg.BorderSizePixel = 0
    sbg.Parent = ctr
    Instance.new("UICorner", sbg).CornerRadius = UDim.new(1, 0)

    local sf = Instance.new("Frame")
    sf.Size = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0)
    sf.BackgroundColor3 = C.Accent
    sf.BorderSizePixel = 0
    sf.Parent = sbg
    Instance.new("UICorner", sf).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(1, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel = 0
    knob.Parent = sf
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local sBtn = Instance.new("TextButton")
    sBtn.Size = UDim2.new(1, 0, 0, 24)
    sBtn.Position = UDim2.new(0, 0, 0, 25)
    sBtn.BackgroundTransparency = 1
    sBtn.Text = ""
    sBtn.Parent = ctr

    local dragging = false
    local function upd(x)
        local r = math.clamp((x - sbg.AbsolutePosition.X) / sbg.AbsoluteSize.X, 0, 1)
        local v = math.floor(min + (max - min) * r)
        sf.Size = UDim2.new(r, 0, 1, 0)
        vl.Text = tostring(v)
        pcall(cb, v)
    end

    sBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; upd(i.Position.X)
        end
    end)
    sBtn.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            upd(i.Position.X)
        end
    end)
end

