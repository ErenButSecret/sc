-- ÖZELLİK: ESP
-- ═══════════════════════════════════════════
local function createESPForPlayer(target)
    if target == player or ESPObjects[target.Name] then return end

    -- Takım kontrolü
    if State.ESP_TeamCheck and target.Team and player.Team and target.Team == player.Team then
        return
    end

    local function setup()
        local ch = target.Character
        if not ch then return end
        local head = ch:FindFirstChild("Head")
        local hum = ch:FindFirstChildOfClass("Humanoid")
        local root = ch:FindFirstChild("HumanoidRootPart")
        if not head or not hum or not root then return end

        -- Highlight
        local hl = Instance.new("Highlight")
        hl.Name = "KiwiESP"
        hl.FillColor = C.Accent
        hl.FillTransparency = State.ESP_FillTransparency
        hl.OutlineColor = C.Accent
        hl.OutlineTransparency = 0.3
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = ch
        hl.Parent = ch

        -- Billboard
        local bb = Instance.new("BillboardGui")
        bb.Name = "KiwiESP_BB"
        bb.Adornee = head
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        bb.Parent = head

        -- İsim
        local nameL = Instance.new("TextLabel")
        nameL.Size = UDim2.new(1, 0, 0, 18)
        nameL.BackgroundTransparency = 1
        nameL.Text = target.Name
        nameL.TextSize = 14
        nameL.Font = Enum.Font.GothamBold
        nameL.TextColor3 = C.Accent
        nameL.TextStrokeTransparency = 0.4
        nameL.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameL.Parent = bb

        -- Bilgi satırı (HP + Mesafe)
        local infoL = Instance.new("TextLabel")
        infoL.Name = "Info"
        infoL.Size = UDim2.new(1, 0, 0, 14)
        infoL.Position = UDim2.new(0, 0, 0, 18)
        infoL.BackgroundTransparency = 1
        infoL.TextSize = 12
        infoL.Font = Enum.Font.GothamMedium
        infoL.TextColor3 = C.Text
        infoL.TextStrokeTransparency = 0.4
        infoL.TextStrokeColor3 = Color3.new(0, 0, 0)
        infoL.Parent = bb

        -- HP Bar arka plan
        local hpBarBg = Instance.new("Frame")
        hpBarBg.Name = "HPBarBg"
        hpBarBg.Size = UDim2.new(0.6, 0, 0, 4)
        hpBarBg.Position = UDim2.new(0.2, 0, 0, 35)
        hpBarBg.AnchorPoint = Vector2.new(0, 0)
        hpBarBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBarBg.BorderSizePixel = 0
        hpBarBg.Parent = bb
        Instance.new("UICorner", hpBarBg).CornerRadius = UDim.new(1, 0)

        -- HP Bar dolgu
        local hpBarFill = Instance.new("Frame")
        hpBarFill.Name = "Fill"
        hpBarFill.Size = UDim2.new(1, 0, 1, 0)
        hpBarFill.BackgroundColor3 = C.Success
        hpBarFill.BorderSizePixel = 0
        hpBarFill.Parent = hpBarBg
        Instance.new("UICorner", hpBarFill).CornerRadius = UDim.new(1, 0)

        ESPObjects[target.Name] = {HL = hl, BB = bb, Info = infoL, HPBg = hpBarBg, HPFill = hpBarFill}

        -- Güncelleme döngüsü
        local uc
        uc = RunService.Heartbeat:Connect(function()
            if not State.ESPEnabled or not ch.Parent or not hum.Parent then
                uc:Disconnect()
                return
            end

            -- Bilgi metni
            local parts = {}
            if State.ESP_ShowHealth then
                parts[#parts + 1] = string.format("HP: %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth))
            end
            local myRoot = getRoot()
            if State.ESP_ShowDistance and myRoot and root and root.Parent then
                parts[#parts + 1] = math.floor((myRoot.Position - root.Position).Magnitude) .. "m"
            end
            infoL.Text = table.concat(parts, " | ")

            -- HP bar güncelle
            local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            hpBarFill.Size = UDim2.new(hpRatio, 0, 1, 0)

            -- HP rengine göre renk değiştir
            if hpRatio > 0.6 then
                hpBarFill.BackgroundColor3 = C.Success
                hl.OutlineColor = C.Accent
            elseif hpRatio > 0.3 then
                hpBarFill.BackgroundColor3 = C.Warning
                hl.OutlineColor = C.Warning
            else
                hpBarFill.BackgroundColor3 = C.Danger
                hl.OutlineColor = C.Danger
            end

            -- HP bar görünürlük
            hpBarBg.Visible = State.ESP_ShowHealth

            -- Fill transparency güncelle
            hl.FillTransparency = State.ESP_FillTransparency
        end)
        addConn("ESP_U_" .. target.Name, uc)
    end

    setup()

    -- Karakter yenilenince tekrar kur
    addConn("ESP_CA_" .. target.Name, target.CharacterAdded:Connect(function()
        task.wait(0.5)
        if ESPObjects[target.Name] then
            pcall(function() ESPObjects[target.Name].HL:Destroy() end)
            pcall(function() ESPObjects[target.Name].BB:Destroy() end)
            ESPObjects[target.Name] = nil
        end
        if State.ESPEnabled then setup() end
    end))
end

local function removeESPForPlayer(name)
    if ESPObjects[name] then
        pcall(function() ESPObjects[name].HL:Destroy() end)
        pcall(function() ESPObjects[name].BB:Destroy() end)
        ESPObjects[name] = nil
    end
    removeConn("ESP_U_" .. name)
    removeConn("ESP_CA_" .. name)
end

local function toggleESP(on)
    State.ESPEnabled = on
    if on then
        for _, p in pairs(Players:GetPlayers()) do
            createESPForPlayer(p)
        end
        addConn("ESP_PA", Players.PlayerAdded:Connect(function(p)
            task.wait(1)
            if State.ESPEnabled then createESPForPlayer(p) end
        end))
        addConn("ESP_PR", Players.PlayerRemoving:Connect(function(p)
            removeESPForPlayer(p.Name)
        end))
    else
        for name in pairs(ESPObjects) do
            removeESPForPlayer(name)
        end
        removeConn("ESP_PA")
        removeConn("ESP_PR")
    end
end

-- ESP'yi yenile (config değiştiğinde)
local function refreshESP()
    if State.ESPEnabled then
        toggleESP(false)
        task.wait(0.1)
        toggleESP(true)
    end
end

