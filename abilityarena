-- ÖZELLİK: SPEED
-- ═══════════════════════════════════════════
local function toggleSpeed(on)
    State.SpeedEnabled = on
    if on then
        addConn("Speed", RunService.Heartbeat:Connect(function()
            local hum = getHum()
            if hum then
                -- Q Boost aktifse ve Q basılıysa boost hızını kullan
                if State.QBoostEnabled and QHeld then
                    hum.WalkSpeed = State.QBoostSpeed
                else
                    hum.WalkSpeed = State.SpeedValue
                end
            end
        end))
    else
        removeConn("Speed")
        local hum = getHum()
        if hum then hum.WalkSpeed = 16 end
    end
end

-- ═══════════════════════════════════════════
-- ÖZELLİK: Q BOOST
-- ═══════════════════════════════════════════
local function toggleQBoost(on)
    State.QBoostEnabled = on
    if on then
        addConn("QBoost_Down", UserInputService.InputBegan:Connect(function(input, processed)
            if processed then return end
            if input.KeyCode == Enum.KeyCode.Q then
                QHeld = true
                -- Speed hack kapalıysa bile Q Boost çalışsın
                if not State.SpeedEnabled then
                    addConn("QBoost_Loop", RunService.Heartbeat:Connect(function()
                        if QHeld and State.QBoostEnabled then
                            local hum = getHum()
                            if hum then hum.WalkSpeed = State.QBoostSpeed end
                        end
                    end))
                end
            end
        end))
        addConn("QBoost_Up", UserInputService.InputEnded:Connect(function(input)
            if input.KeyCode == Enum.KeyCode.Q then
                QHeld = false
                removeConn("QBoost_Loop")
                -- Speed hack açıksa o hıza dön, kapalıysa normal hıza dön
                local hum = getHum()
                if hum then
                    if State.SpeedEnabled then
                        hum.WalkSpeed = State.SpeedValue
                    else
                        hum.WalkSpeed = 16
                    end
                end
            end
        end))
    else
        QHeld = false
        removeConn("QBoost_Down")
        removeConn("QBoost_Up")
        removeConn("QBoost_Loop")
        -- Normal hıza dön
        local hum = getHum()
        if hum then
            if State.SpeedEnabled then
                hum.WalkSpeed = State.SpeedValue
            else
                hum.WalkSpeed = 16
            end
        end
    end
end

-- ═══════════════════════════════════════════
-- ÖZELLİK: ANTI-KNOCKBACK
-- ═══════════════════════════════════════════
local function toggleAntiKnockback(on)
    State.AntiKnockbackEnabled = on
    if on then
        addConn("AntiKB", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if root then
                -- Velocity'yi sıfırla (sadece X ve Z, Y dokunma ki düşüş/zıplama bozulmasın)
                pcall(function()
                    local vel = root.AssemblyLinearVelocity
                    -- Eğer X veya Z hızı çok yüksekse (knockback) sıfırla
                    if math.abs(vel.X) > 50 or math.abs(vel.Z) > 50 then
                        root.AssemblyLinearVelocity = Vector3.new(0, vel.Y, 0)
                    end
                end)

                -- BodyVelocity, BodyForce gibi knockback kaynakları varsa kaldır
                for _, child in pairs(root:GetChildren()) do
                    if (child:IsA("BodyVelocity") or child:IsA("BodyForce") or child:IsA("VectorForce"))
                        and not child.Name:find("Kiwi") then
                        child:Destroy()
                    end
                end
            end
        end))
    else
        removeConn("AntiKB")
    end
end

-- ═══════════════════════════════════════════
-- ÖZELLİK: ANTI-RAGDOLL
-- ═══════════════════════════════════════════
local function toggleAntiRagdoll(on)
    State.AntiRagdollEnabled = on
    if on then
        addConn("AntiRagdoll", RunService.Heartbeat:Connect(function()
            local hum = getHum()
            local char = getChar()
            if not hum or not char then return end

            -- Ragdoll ve düşme state'lerini engelle
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            end)

            -- Eğer ragdoll state'indeyse zorla çıkar
            local currentState = hum:GetState()
            if currentState == Enum.HumanoidStateType.Ragdoll
                or currentState == Enum.HumanoidStateType.FallingDown then
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end

            -- Ragdoll için eklenen constraint'leri kaldır
            for _, part in pairs(char:GetDescendants()) do
                -- BallSocketConstraint (ragdoll eklemi)
                if part:IsA("BallSocketConstraint") and part.Name:lower():find("ragdoll") then
                    part:Destroy()
                end
                -- Ragdoll attribute kontrolü
                if part:IsA("BasePart") then
                    pcall(function()
                        if part:GetAttribute("Ragdolled") then
                            part:SetAttribute("Ragdolled", false)
                        end
                    end)
                end
            end

            -- Humanoid PlatformStand kapalı tut (ragdoll bunu açar)
            if hum.PlatformStand then
                hum.PlatformStand = false
            end

            -- Tüm Motor6D'leri aktif tut
            for _, motor in pairs(char:GetDescendants()) do
                if motor:IsA("Motor6D") then
                    motor.Enabled = true
                end
            end
        end))
    else
        removeConn("AntiRagdoll")
        -- State'leri geri aç
        local hum = getHum()
        if hum then
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
                hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            end)
        end
    end
end

