-- ÖZELLİK: PUNCH AURA
-- ═══════════════════════════════════════════
local function togglePunchAura(on)
    State.PunchAuraEnabled = on
    if on then
        task.spawn(function()
            while State.PunchAuraEnabled do
                local root = getRoot()
                local char = getChar()
                if root then
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= player and p.Character then
                            local enemyRoot = p.Character:FindFirstChild("HumanoidRootPart")
                            local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
                            if enemyRoot and enemyHum and enemyHum.Health > 0 then
                                local dist = (root.Position - enemyRoot.Position).Magnitude
                                if dist <= State.PunchAuraRange then
                                    -- Karakter punch/attack animasyonu tetikle
                                    pcall(function()
                                        -- Yöntem 1: Tool varsa aktif et
                                        local tool = char:FindFirstChildOfClass("Tool")
                                        if tool then
                                            tool:Activate()
                                        end

                                        -- Yöntem 2: Click detector
                                        local clickDet = enemyRoot:FindFirstChildOfClass("ClickDetector")
                                        if clickDet then
                                            fireclickdetector(clickDet)
                                        end

                                        -- Yöntem 3: Remote event ara ve ateşle
                                        -- Oyuna özel remote adını buraya yaz:
                                        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("Punch")
                                            or game:GetService("ReplicatedStorage"):FindFirstChild("Attack")
                                            or game:GetService("ReplicatedStorage"):FindFirstChild("Combat")
                                            or game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
                                        if remote and remote:IsA("RemoteEvent") then
                                            remote:FireServer(enemyRoot.Position)
                                        end

                                        -- Yöntem 4: Humanoid ile yakınlaş ve vur
                                        local hum = getHum()
                                        if hum then
                                            -- Düşmana doğru bak
                                            root.CFrame = CFrame.lookAt(root.Position, enemyRoot.Position)
                                        end
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(State.PunchAuraDelay)
            end
        end)
    end
end

-- ═══════════════════════════════════════════
-- ÖZELLİK: KILL AURA
-- ═══════════════════════════════════════════
local function toggleKillAura(on)
    State.KillAuraEnabled = on
    if on then
        task.spawn(function()
            while State.KillAuraEnabled do
                local root = getRoot()
                local char = getChar()
                if root and char then
                    -- Etraftaki tüm düşmanlara saldır
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= player and p.Character then
                            local enemyRoot = p.Character:FindFirstChild("HumanoidRootPart")
                            local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
                            if enemyRoot and enemyHum and enemyHum.Health > 0 then
                                local dist = (root.Position - enemyRoot.Position).Magnitude
                                if dist <= State.KillAuraRange then
                                    pcall(function()
                                        -- Tool'u aktif et
                                        local tool = char:FindFirstChildOfClass("Tool")
                                        if tool then
                                            tool:Activate()
                                        end

                                        -- Remote'ları ara
                                        local rs = game:GetService("ReplicatedStorage")
                                        for _, child in pairs(rs:GetDescendants()) do
                                            if child:IsA("RemoteEvent") and
                                               (child.Name:lower():find("attack") or
                                                child.Name:lower():find("damage") or
                                                child.Name:lower():find("hit") or
                                                child.Name:lower():find("punch") or
                                                child.Name:lower():find("combat")) then
                                                pcall(function()
                                                    child:FireServer(p, enemyRoot.Position)
                                                end)
                                            end
                                        end
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0.05)
            end
        end)
    end
end

-- ═══════════════════════════════════════════
-- ÖZELLİK: AUTO PARRY
-- ═══════════════════════════════════════════
local function toggleAutoParry(on)
    State.AutoParryEnabled = on
    if on then
        task.spawn(function()
            while State.AutoParryEnabled do
                local root = getRoot()
                if root then
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= player and p.Character then
                            local enemyRoot = p.Character:FindFirstChild("HumanoidRootPart")
                            local enemyHum = p.Character:FindFirstChildOfClass("Humanoid")
                            if enemyRoot and enemyHum and enemyHum.Health > 0 then
                                local dist = (root.Position - enemyRoot.Position).Magnitude
                                if dist <= 20 then
                                    -- Animasyon kontrol et - saldırı animasyonu çalıyorsa parry yap
                                    pcall(function()
                                        local animator = enemyHum:FindFirstChildOfClass("Animator")
                                        if animator then
                                            for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                                                local name = track.Name:lower()
                                                if name:find("attack") or name:find("punch") or
                                                   name:find("swing") or name:find("slash") or
                                                   name:find("hit") or name:find("combo") then
                                                    -- Parry remote'u ateşle
                                                    local rs = game:GetService("ReplicatedStorage")
                                                    local parryRemote = rs:FindFirstChild("Parry")
                                                        or rs:FindFirstChild("Block")
                                                        or rs:FindFirstChild("Defend")
                                                    if parryRemote and parryRemote:IsA("RemoteEvent") then
                                                        parryRemote:FireServer()
                                                    end
                                                    break
                                                end
                                            end
                                        end
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0.03)
            end
        end)
    end
end

