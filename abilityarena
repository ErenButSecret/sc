-- Geri Işınlama
local function toggleAV_Teleport(on)
    State.AV_TeleportEnabled = on
    if on then
        addConn("AV_Teleport", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if not root then return end
            if root.Position.Y > State.AV_Y + 5 then
                AV_LastSafePos = root.CFrame
            end
            if root.Position.Y <= State.AV_Y then
                if AV_LastSafePos then
                    root.CFrame = AV_LastSafePos
                else
                    root.CFrame = CFrame.new(root.Position.X, State.AV_Y + 20, root.Position.Z)
                end
                pcall(function() root.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
                pcall(function() root.Velocity = Vector3.new(0, 0, 0) end)
            end
        end))
    else
        removeConn("AV_Teleport")
    end
end

-- Dondurma
local function toggleAV_Freeze(on)
    State.AV_FreezeEnabled = on
    if on then
        addConn("AV_Freeze", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if not root then return end
            if root.Position.Y <= State.AV_Y then
                root.Anchored = true
                root.CFrame = CFrame.new(root.Position.X, State.AV_Y, root.Position.Z) * (root.CFrame - root.CFrame.Position)
            else
                if root.Anchored then root.Anchored = false end
            end
        end))
    else
        removeConn("AV_Freeze")
        local root = getRoot()
        if root then root.Anchored = false end
    end
end

-- Platform
local function toggleAV_Platform(on)
    State.AV_PlatformEnabled = on
    if on then
        if AV_Platform and AV_Platform.Parent then AV_Platform:Destroy() end
        local plat = Instance.new("Part")
        plat.Name = "KiwiAntiVoidPlatform"
        plat.Anchored = true
        plat.CanCollide = true
        plat.Size = Vector3.new(2048, 1, 2048)
        plat.Position = Vector3.new(0, State.AV_Y - 1, 0)
        plat.Transparency = 1
        plat.Material = Enum.Material.ForceField
        plat.Color = C.Accent
        plat.Parent = Workspace
        AV_Platform = plat
        addConn("AV_Platform", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if root and plat and plat.Parent then
                plat.Position = Vector3.new(root.Position.X, State.AV_Y - 1, root.Position.Z)
            end
        end))
    else
        removeConn("AV_Platform")
        if AV_Platform and AV_Platform.Parent then AV_Platform:Destroy(); AV_Platform = nil end
    end
end

-- Zıplatma
local function toggleAV_Bounce(on)
    State.AV_BounceEnabled = on
    if on then
        addConn("AV_Bounce", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if not root then return end
            if root.Position.Y <= State.AV_Y + 3 then
                pcall(function()
                    root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X * 0.5, 80, root.AssemblyLinearVelocity.Z * 0.5)
                end)
                pcall(function()
                    root.Velocity = Vector3.new(root.Velocity.X * 0.5, 80, root.Velocity.Z * 0.5)
                end)
            end
        end))
    else
        removeConn("AV_Bounce")
    end
end

-- Havada Tutma
local function toggleAV_Float(on)
    State.AV_FloatEnabled = on
    if on then
        addConn("AV_Float", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if not root then return end
            if root.Position.Y <= State.AV_Y + 2 then
                if not AV_BodyPos or not AV_BodyPos.Parent then
                    local bp = Instance.new("BodyPosition")
                    bp.Name = "KiwiAntiVoidFloat"
                    bp.MaxForce = Vector3.new(0, math.huge, 0)
                    bp.D = 1000
                    bp.P = 10000
                    bp.Parent = root
                    AV_BodyPos = bp
                end
                AV_BodyPos.Position = Vector3.new(root.Position.X, State.AV_Y + 3, root.Position.Z)
            else
                if AV_BodyPos and AV_BodyPos.Parent then AV_BodyPos:Destroy(); AV_BodyPos = nil end
            end
        end))
    else
        removeConn("AV_Float")
        if AV_BodyPos and AV_BodyPos.Parent then AV_BodyPos:Destroy(); AV_BodyPos = nil end
    end
end

