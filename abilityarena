local tabBtns = {}
local tabPages = {}
local activeTab = nil

for i, tab in ipairs(tabDefs) do
    local page = createPage(tab.Name)
    tabPages[tab.Name] = page

    local tb = Instance.new("TextButton")
    tb.Size = UDim2.new(1, -16, 0, 38)
    tb.Position = UDim2.new(0, 8, 0, 8 + (i - 1) * 46)
    tb.BackgroundTransparency = 1
    tb.BorderSizePixel = 0
    tb.Text = tab.Icon .. "  " .. tab.Name
    tb.TextSize = 13
    tb.Font = Enum.Font.GothamBold
    tb.TextColor3 = C.TextDim
    tb.TextXAlignment = Enum.TextXAlignment.Left
    tb.AutoButtonColor = false
    tb.Parent = sidebar
    Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 8)
    Instance.new("UIPadding", tb).PaddingLeft = UDim.new(0, 12)

    local ind = Instance.new("Frame")
    ind.Size = UDim2.new(0, 3, 0.5, 0)
    ind.Position = UDim2.new(0, -8, 0.25, 0)
    ind.BackgroundColor3 = tab.Color
    ind.BackgroundTransparency = 1
    ind.BorderSizePixel = 0
    ind.Parent = tb
    Instance.new("UICorner", ind).CornerRadius = UDim.new(1, 0)

    tabBtns[tab.Name] = {Btn = tb, Ind = ind, Color = tab.Color}

    tb.MouseEnter:Connect(function()
        if activeTab ~= tab.Name then tw(tb, 0.2, {BackgroundTransparency = 0.5, TextColor3 = C.Text}) end
    end)
    tb.MouseLeave:Connect(function()
        if activeTab ~= tab.Name then tw(tb, 0.2, {BackgroundTransparency = 1, TextColor3 = C.TextDim}) end
    end)
    tb.MouseButton1Click:Connect(function()
        for n, d in pairs(tabBtns) do
            tw(d.Btn, 0.25, {BackgroundTransparency = 1, TextColor3 = C.TextDim})
            tw(d.Ind, 0.25, {BackgroundTransparency = 1})
            tabPages[n].Visible = false
        end
        activeTab = tab.Name
        tw(tb, 0.25, {BackgroundTransparency = 0.3, TextColor3 = tab.Color})
        tw(ind, 0.25, {BackgroundTransparency = 0})
        page.Visible = true
    end)
end

