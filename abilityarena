-- ÖZELLİK: ESP
-- ═══════════════════════════════════════════
local function createESP(target)
    if target == player or ESPObjects[target.Name] then return end
    local function setup()
        local ch = target.Character
        if not ch then return end
        local head = ch:FindFirstChild("Head")
        local hum = ch:FindFirstChildOfClass("Humanoid")
        local root = ch:FindFirstChild("HumanoidRootPart")
        if not head or not hum or not root then return end

        local hl = Instance.new("Highlight")
        hl.Name = "KiwiESP"
        hl.FillColor = C.Accent
        hl.FillTransparency = 0.7
        hl.OutlineColor = C.Accent
        hl.OutlineTransparency = 0.3
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Adornee = ch
        hl.Parent = ch

        local bb = Instance.new("BillboardGui")
        bb.Name = "KiwiESP_BB"
        bb.Adornee = head
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        bb.Parent = head

        local nameL = Instance.new("TextLabel")
        nameL.Size = UDim2.new(1, 0, 0, 18)
        nameL.BackgroundTransparency = 1
        nameL.Text = target.Name
        nameL.TextSize = 14
        nameL.Font = Enum.Font.GothamBold
        nameL.TextColor3 = C.Accent
        nameL.TextStrokeTransparency = 0.5
        nameL.TextStrokeColor3 = Color3.new(0, 0, 0)
        nameL.Parent = bb

        local infoL = Instance.new("TextLabel")
        infoL.Size = UDim2.new(1, 0, 0, 14)
        infoL.Position = UDim2.new(0, 0, 0, 18)
        infoL.BackgroundTransparency = 1
        infoL.TextSize = 12
        infoL.Font = Enum.Font.GothamMedium
        infoL.TextColor3 = C.Text
        infoL.TextStrokeTransparency = 0.5
        infoL.TextStrokeColor3 = Color3.new(0, 0, 0)
        infoL.Parent = bb

        ESPObjects[target.Name] = {HL = hl, BB = bb, Info = infoL}

        local uc
        uc = RunService.Heartbeat:Connect(function()
            if not State.ESPEnabled or not ch.Parent or not hum.Parent then uc:Disconnect() return end
            local myRoot = getRoot()
            local parts = {}
            parts[#parts+1] = string.format("HP: %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth))
            if myRoot and root and root.Parent then
                parts[#parts+1] = math.floor((myRoot.Position - root.Position).Magnitude) .. "m"
            end
            infoL.Text = table.concat(parts, " | ")
            local r = hum.Health / hum.MaxHealth
            hl.OutlineColor = r > 0.6 and C.Accent or r > 0.3 and C.Warning or C.Danger
        end)
        addConn("ESP_U_" .. target.Name, uc)
    end
    setup()
    addConn("ESP_CA_" .. target.Name, target.CharacterAdded:Connect(function()
        task.wait(0.5)
        if ESPObjects[target.Name] then
            pcall(function() ESPObjects[target.Name].HL:Destroy() end)
            pcall(function() ESPObjects[target.Name].BB:Destroy() end)
            ESPObjects[target.Name] = nil
        end
        if State.ESPEnabled then setup() end
    end))
end

local function removeESP(name)
    if ESPObjects[name] then
        pcall(function() ESPObjects[name].HL:Destroy() end)
        pcall(function() ESPObjects[name].BB:Destroy() end)
        ESPObjects[name] = nil
    end
    removeConn("ESP_U_" .. name)
    removeConn("ESP_CA_" .. name)
end

local function toggleESP(on)
    State.ESPEnabled = on
    if on then
        for _, p in pairs(Players:GetPlayers()) do createESP(p) end
        addConn("ESP_PA", Players.PlayerAdded:Connect(function(p) task.wait(1) if State.ESPEnabled then createESP(p) end end))
        addConn("ESP_PR", Players.PlayerRemoving:Connect(function(p) removeESP(p.Name) end))
    else
        for n in pairs(ESPObjects) do removeESP(n) end
        removeConn("ESP_PA")
        removeConn("ESP_PR")
    end
end

