local lastSafePos = nil

local function toggleAntiVoid(on)
    State.AntiVoidEnabled = on
    if on then
        addConn("AntiVoid", RunService.Heartbeat:Connect(function()
            local root = getRoot()
            if root then
                if root.Position.Y > State.AntiVoidY + 10 then
                    lastSafePos = root.CFrame
                elseif root.Position.Y <= State.AntiVoidY then
                    if lastSafePos then
                        root.CFrame = lastSafePos
                        root.Velocity = Vector3.new(0, 0, 0)
                        -- AssemblyLinearVelocity de sıfırla (yeni Roblox)
                        pcall(function() root.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
                    else
                        root.CFrame = CFrame.new(0, 100, 0)
                    end
                end
            end
        end))
    else
        removeConn("AntiVoid")
    end
end

