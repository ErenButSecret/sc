    local vL = Instance.new("TextLabel", cont) vL.Size, vL.Position, vL.BackgroundTransparency, vL.Text, vL.Font, vL.TextSize, vL.TextColor3, vL.TextXAlignment = UDim2.new(0.35, 0, 0, 20), UDim2.new(0.65, -14, 0, 6), 1, tostring(def), Enum.Font.GothamBold, 13, Colors.Accent, Enum.TextXAlignment.Right
    local sBg = Instance.new("Frame", cont) sBg.Size, sBg.Position, sBg.BackgroundColor3, sBg.BorderSizePixel = UDim2.new(1, -28, 0, 6), UDim2.new(0, 14, 0, 36), Colors.SliderBg, 0 Instance.new("UICorner", sBg).CornerRadius = UDim.new(1, 0)
    local sFill = Instance.new("Frame", sBg) sFill.Size, sFill.BackgroundColor3, sFill.BorderSizePixel = UDim2.new((def-min)/(max-min), 0, 1, 0), Colors.Accent, 0 Instance.new("UICorner", sFill).CornerRadius = UDim.new(1, 0)
    local btn, dragging = Instance.new("TextButton", cont), false
    btn.Size, btn.Position, btn.BackgroundTransparency, btn.Text = UDim2.new(1, 0, 0, 24), UDim2.new(0, 0, 0, 25), 1, ""
    
    local function update(posX)
        local relX = math.clamp((posX - sBg.AbsolutePosition.X) / sBg.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * relX)
        sFill.Size = UDim2.new(relX, 0, 1, 0) vL.Text = tostring(val) pcall(callback, val)
    end
    btn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i.Position.X) end end)
    btn.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i.Position.X) end end)
end

