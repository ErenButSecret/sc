local function createSlider(parent, label, min, max, def, order, callback)
    local cont = Instance.new("Frame", parent) cont.Size, cont.BackgroundColor3, cont.LayoutOrder, cont.BorderSizePixel = UDim2.new(1, 0, 0, 58), Colors.Card, order, 0 Instance.new("UICorner", cont).CornerRadius = UDim.new(0, 8)
